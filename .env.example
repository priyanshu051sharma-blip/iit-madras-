# Application Environment
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI API (for AI Legal Assistant)
NEXT_PUBLIC_OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4

# Google Gemini API (Alternative to OpenAI)
NEXT_PUBLIC_GOOGLE_GEMINI_KEY=your-gemini-key

# Mapbox (for maps and geo-fencing)
NEXT_PUBLIC_MAPBOX_TOKEN=pk-your-mapbox-token

# Google Maps (alternative)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-key

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/drivelegal
DIRECT_URL=postgresql://user:password@localhost:5432/drivelegal

# Redis Cache
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-super-secret-jwt-key
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# Email Service (SendGrid)
SENDGRID_API_KEY=your-sendgrid-key
SENDGRID_FROM_EMAIL=noreply@drivelegal.app

# SMS Service (Twilio)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# File Storage (AWS S3)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=drivelegal-storage
AWS_S3_REGION=ap-south-1

# Monitoring & Analytics
SENTRY_DSN=your-sentry-dsn
NEXT_PUBLIC_GA_ID=your-google-analytics-id
LOGROCKET_APP_ID=your-logrocket-id

# OCR Service
GOOGLE_CLOUD_VISION_KEY=your-vision-api-key

# Feature Flags
FEATURE_AI_CHAT=true
FEATURE_ANALYTICS=true
FEATURE_OFFLINE=true
FEATURE_POLICE_PORTAL=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://drivelegal.app

# Debug
DEBUG=drivelegal:*
LOG_LEVEL=info
